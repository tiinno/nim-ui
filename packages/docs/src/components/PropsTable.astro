---
/**
 * PropsTable - Document component props in a clean table format
 *
 * @example
 * <PropsTable
 *   props={[
 *     {
 *       name: 'variant',
 *       type: "'primary' | 'secondary' | 'outline'",
 *       default: "'primary'",
 *       description: 'Visual style variant'
 *     }
 *   ]}
 * />
 */

export interface PropDefinition {
  name: string;
  type: string;
  default?: string;
  required?: boolean;
  description: string;
}

interface Props {
  props: PropDefinition[];
}

const { props } = Astro.props;
---

<div class="not-content my-6 overflow-x-auto rounded-lg border border-neutral-200 shadow-soft dark:border-neutral-800">
  <table class="min-w-full divide-y divide-neutral-200 dark:divide-neutral-800">
    <thead class="bg-neutral-50 dark:bg-neutral-900">
      <tr>
        <th
          scope="col"
          class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider"
        >
          Name
        </th>
        <th
          scope="col"
          class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider"
        >
          Type
        </th>
        <th
          scope="col"
          class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider"
        >
          Default
        </th>
        <th
          scope="col"
          class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider"
        >
          Description
        </th>
      </tr>
    </thead>
    <tbody class="bg-white dark:bg-neutral-950 divide-y divide-neutral-200 dark:divide-neutral-800">
      {
        props.map((prop) => (
          <tr class="hover:bg-neutral-50 dark:hover:bg-neutral-900">
            <td class="px-6 py-4 whitespace-nowrap">
              <code class="text-sm font-mono font-medium text-neutral-900 dark:text-neutral-100">
                {prop.name}
                {prop.required && (
                  <span class="text-error-500 ml-1">*</span>
                )}
              </code>
            </td>
            <td class="px-6 py-4">
              <code class="text-sm font-mono text-primary-700 dark:text-primary-300 whitespace-pre-wrap">
                {prop.type}
              </code>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              {prop.default ? (
                <code class="text-sm font-mono text-neutral-600 dark:text-neutral-400">
                  {prop.default}
                </code>
              ) : (
                <span class="text-sm text-neutral-400 dark:text-neutral-600">-</span>
              )}
            </td>
            <td class="px-6 py-4 text-sm text-neutral-700 dark:text-neutral-300">
              {prop.description}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  /* Ensure table is scrollable on mobile */
  @media (max-width: 640px) {
    table {
      font-size: 0.875rem;
    }

    td,
    th {
      padding: 0.5rem 1rem;
    }
  }
</style>
